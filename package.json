{
  "name": "toolroute",
  "version": "0.2.0",
  "description": "Vercel AI SDK companion that turns tool definitions into a typed routing graph.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "COMPATIBILITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test",
    "smoke": "node ./scripts/smoke.mjs",
    "example:code-review": "tsx examples/code-review-agent/run.ts"
  },
  "keywords": [
    "vercel-ai-sdk",
    "ai",
    "agents",
    "typescript",
    "tool-calling",
    "state-machine",
    "type-safety"
  ],
  "homepage": "https://github.com/nkwib/toolroute#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nkwib/toolroute.git"
  },
  "bugs": {
    "url": "https://github.com/nkwib/toolroute/issues"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <7",
    "zod": ">=3.23.0 <5"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
